pipeline {
    agent any

    tools {
        nodejs 'Node25'
        sonarScanner 'sonar-scanner'
    }
    stages {

        stage('Install') {
            steps {
                dir('backend') {
                    sh 'npm install'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('backend') {
                    withSonarQubeEnv('sq1') {
                        sh """
                            sonar-scanner \
                              -Dsonar.projectKey=formify-backend \
                              -Dsonar.sources=. \
                              -Dsonar.exclusions=node_modules/**
                        """
                    }
                }
            }
        }
    }
}
