pipeline {
    agent any

    tools {
        nodejs 'Node25'
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }
        stage('SonarQube Analysis') {
            steps {
                dir('backend') {
                    script {
                        scannerHome = tool 'sonar-scanner'
                    }
                    withSonarQubeEnv('sq1') {
                         sh """
                                ${scannerHome}/bin/sonar-scanner
                            """
                    }                 
                }
            }
        }
        
        stage('Build and Push Docker Image') {
            steps {
                dir('backend') {
                    script {
                        docker.withRegistry('', 'docker-credential') {
                            def customImage = docker.build("pantherlord/formify-backend:latest")
                            customImage.push()
                        }
                    }
                }
            }
        }
    }
}